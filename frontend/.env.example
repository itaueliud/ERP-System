# Frontend Environment Configuration

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Firebase Configuration (for push notifications)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# GitHub OAuth Configuration
VITE_GITHUB_CLIENT_ID=your_github_client_id

# Application Configuration
VITE_APP_NAME=TechSwiftTrix ERP
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_GITHUB_INTEGRATION=true
VITE_ENABLE_PROPERTY_LISTINGS=true

# File Upload Configuration
VITE_MAX_FILE_SIZE_MB=50
VITE_ALLOWED_FILE_TYPES=pdf,docx,xlsx,png,jpg,jpeg,gif

# Map Configuration (for property listings)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token

# CDN Configuration (Req 37.6)
# Set to your CDN origin (e.g. https://cdn.techswifttrix.com) to serve static
# assets from a CDN in production. Leave empty to serve from the same origin.
VITE_CDN_BASE_URL=
