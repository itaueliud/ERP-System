{
  "name": "@techswifttrix/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TechSwiftTrix ERP Frontend Portals",
  "scripts": {
    "dev": "vite",
    "dev:ceo": "vite --config vite.config.ceo.ts",
    "dev:executive": "vite --config vite.config.executive.ts",
    "dev:clevel": "vite --config vite.config.clevel.ts",
    "dev:operations": "vite --config vite.config.operations.ts",
    "dev:technology": "vite --config vite.config.technology.ts",
    "dev:agents": "vite --config vite.config.agents.ts",
    "dev:all": "concurrently -n CEO,EXEC,CLVL,OPS,TECH,AGNT -c cyan,blue,gray,green,indigo,orange \"npm run dev:ceo\" \"npm run dev:executive\" \"npm run dev:clevel\" \"npm run dev:operations\" \"npm run dev:technology\" \"npm run dev:agents\"",
    "build": "node_modules/.bin/tsc && node_modules/.bin/vite build",
    "build:ceo": "tsc && vite build --config vite.config.ceo.ts",
    "build:executive": "tsc && vite build --config vite.config.executive.ts",
    "build:clevel": "tsc && vite build --config vite.config.clevel.ts",
    "build:operations": "tsc && vite build --config vite.config.operations.ts",
    "build:technology": "tsc && vite build --config vite.config.technology.ts",
    "build:agents": "tsc && vite build --config vite.config.agents.ts",
    "preview": "node_modules/.bin/vite preview",
    "test": "node_modules/.bin/vitest --run --config vitest.config.ts",
    "test:watch": "node_modules/.bin/vitest --config vitest.config.ts",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.5",
    "@types/leaflet": "^1.9.21",
    "autoprefixer": "^10.5.0",
    "axios": "^1.4.0",
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001791",
    "chart.js": "^4.3.3",
    "esbuild": "^0.18.20",
    "happy-dom": "^20.9.0",
    "leaflet": "^1.9.4",
    "postcss": "^8.4.27",
    "postcss-load-config": "^6.0.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.14.2",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.0",
    "fast-check": "^4.7.0",
    "typescript": "^5.1.6",
    "vite": "^4.5.14",
    "vitest": "^0.34.1"
  }
}
