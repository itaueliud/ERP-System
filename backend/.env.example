# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techswifttrix_erp
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MIN=10
DB_POOL_MAX=100

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ─────────────────────────────────────────────────────────────────────────────
# Daraja API — SANDBOX (default for development & testing)
#
# The system runs in SANDBOX mode by default — no real money is ever processed.
# All transactions are simulated against https://sandbox.safaricom.co.ke
#
# SANDBOX TEST CREDENTIALS (public Safaricom values — safe to commit):
#   Short code : 174379
#   Pass key   : bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
#   Test phone : 254708374149
#   B2C name   : testapi
#
# To get your own sandbox consumer key/secret (free):
#   1. Go to https://developer.safaricom.co.ke
#   2. Create an account → Create App → enable "Lipa Na M-Pesa Sandbox"
#   3. Copy Consumer Key and Consumer Secret below
#
# Without credentials, the system uses fully simulated (local) responses.
# Use POST /api/v1/payments/sandbox/simulate-webhook to test the full flow.
#
# !! SWITCHING TO PRODUCTION — only the person responsible should do this !!
#   1. Set DARAJA_API_URL=https://api.safaricom.co.ke
#   2. Replace DARAJA_CONSUMER_KEY and DARAJA_CONSUMER_SECRET with production app credentials
#   3. Replace DARAJA_SHORT_CODE with your real paybill / till number
#   4. Replace DARAJA_PASS_KEY with your production Lipa Na M-Pesa pass key
#   5. Set DARAJA_B2C_INITIATOR_NAME and DARAJA_B2C_SECURITY_CREDENTIAL
#   6. Set DARAJA_CALLBACK_URL to your public HTTPS API URL
#   7. Set DARAJA_WEBHOOK_SECRET to a strong random secret
# ─────────────────────────────────────────────────────────────────────────────
DARAJA_API_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=your_sandbox_consumer_key
DARAJA_CONSUMER_SECRET=your_sandbox_consumer_secret
DARAJA_SHORT_CODE=174379
DARAJA_PASS_KEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
DARAJA_CALLBACK_URL=http://localhost:3000
DARAJA_WEBHOOK_SECRET=your_webhook_secret
DARAJA_B2C_INITIATOR_NAME=testapi
DARAJA_B2C_SECURITY_CREDENTIAL=your_sandbox_security_credential

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@techswifttrix.com
SENDGRID_FROM_NAME=TechSwiftTrix ERP

# Africa's Talking Configuration
AFRICAS_TALKING_USERNAME=your_username
AFRICAS_TALKING_API_KEY=your_api_key
AFRICAS_TALKING_SENDER_ID=TechSwift

# File Storage Configuration (AWS S3 or Cloudflare R2)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=techswifttrix-files

# Cloudflare R2 (Alternative to S3)
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=techswifttrix-files

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE_PATH=logs/app.log

# Background Jobs Configuration
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_DB=1

# Notification Configuration
NOTIFICATION_BATCH_INTERVAL_HOURS=4
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=5000

# Report Configuration
DAILY_REPORT_DEADLINE_HOUR=22
DAILY_REPORT_REMINDER_INTERVAL_MINUTES=30
DAILY_REPORT_OVERDUE_HOUR=23

# GitHub Integration Configuration
GITHUB_SYNC_INTERVAL_MINUTES=15

# File Upload Configuration
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,xlsx,png,jpg,jpeg,gif

# Audit Log Configuration
AUDIT_LOG_RETENTION_YEARS=7

# Chat Configuration
CHAT_MESSAGE_RETENTION_DAYS=90
CHAT_MAX_ATTACHMENT_SIZE_MB=10
