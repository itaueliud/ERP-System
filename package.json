{
  "name": "techswifttrix-erp",
  "version": "1.0.0",
  "private": true,
  "description": "TechSwiftTrix ERP System - Multi-tenant Enterprise Resource Platform",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "concurrently -n BACKEND,FRONTEND -c bgBlue.bold,cyan \"npm run dev:backend\" \"npm run dev --workspace=frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:ceo": "npm run dev:ceo --workspace=frontend",
    "dev:executive": "npm run dev:executive --workspace=frontend",
    "dev:clevel": "npm run dev:clevel --workspace=frontend",
    "dev:operations": "npm run dev:operations --workspace=frontend",
    "dev:technology": "npm run dev:technology --workspace=frontend",
    "dev:agents": "npm run dev:agents --workspace=frontend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npx tsc --noEmit -p backend/tsconfig.json && npx tsc --noEmit -p frontend/tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@babel/types": "^7.28.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.18.20",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "pure-rand": "^6.1.0",
    "prettier": "^3.0.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@aws-sdk/core": "^3.974.1",
    "@redis/client": "^5.12.1",
    "async": "^3.2.6",
    "axios": "^1.15.1",
    "bull": "^4.16.5",
    "cron-parser": "^5.5.0",
    "luxon": "^3.7.2",
    "puppeteer": "^24.42.0"
  }
}
